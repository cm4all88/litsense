# ── LitSense Environment Variables ──────────────────────────────────────────
# Copy this to .env.local for local development.
# Add all of these to Vercel → Settings → Environment Variables for production.

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get these from clerk.com → your app → API Keys
# Use pk_test_ / sk_test_ for dev, pk_live_ / sk_live_ for production
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Get these from dashboard.stripe.com → Developers → API Keys
# Use test keys for dev, live keys for production
STRIPE_SECRET_KEY=sk_test_your-key-here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Create these in Stripe → Products → Add Product
# LitSense Plus
VITE_STRIPE_PRICE_PLUS_MONTHLY=price_your-plus-monthly-id
VITE_STRIPE_PRICE_PLUS_ANNUAL=price_your-plus-annual-id
# LitSense Club
VITE_STRIPE_PRICE_CLUB_MONTHLY=price_your-club-monthly-id
VITE_STRIPE_PRICE_CLUB_ANNUAL=price_your-club-annual-id
# Legacy (keep for backward compat)
STRIPE_PRICE_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_YEARLY=price_your-yearly-price-id

# ── Shipping (EasyPost) ───────────────────────────────────────────────────────
# Get from easypost.com → API Keys
EASYPOST_API_KEY=EZTKyour-key-here

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Arbitrary password for /admin — keep this secret
ADMIN_PASSWORD=choose-a-strong-password

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=re_your-key-here
